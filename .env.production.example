# Production domain
APP_URL=https://kawaniai.com
ACME_EMAIL=admin@kawaniai.com

# Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI providers used by HR-AI
GROQ_API_KEY=gsk_...
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FREE_MODEL=llama-3.1-8b-instant
GROQ_CLASSIFIER_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# PayMongo billing webhook: https://kawaniai.com/api/billing/webhook
PAYMONGO_SECRET_KEY=replace_with_paymongo_secret_key
PAYMONGO_WEBHOOK_SECRET=whsk_P3y28L2XtAMydpVkFMjYtJNW

# Hermes Agent gateway/API container
HERMES_API_URL=http://hermes:8642
HERMES_API_KEY=replace-with-openssl-rand-hex-32
HERMES_API_CORS_ORIGINS=https://kawaniai.com,https://hermes.kawaniai.com

# Public Hermes subdomain protection.
# Generate hash on the VPS:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-strong-password'
HERMES_BASIC_AUTH_USER=admin
HERMES_BASIC_AUTH_HASH=$2a$14$replace_with_caddy_hash

# HR-AI MCP endpoint for Hermes.
# Preferred: call /api/mcp with a Supabase user JWT.
# Service-token fallback: set all values below and use Authorization: Bearer HERMES_MCP_TOKEN.
HERMES_MCP_TOKEN=replace-with-openssl-rand-hex-32
HERMES_MCP_USER_ID=00000000-0000-0000-0000-000000000000
HERMES_MCP_COMPANY_ID=00000000-0000-0000-0000-000000000000
HERMES_MCP_EMAIL=hermes@kawaniai.com
HERMES_MCP_ROLE=hr_admin
HERMES_MCP_TOOLS=search_employee,get_employee_profile,list_missing_documents,list_regularization_due,summarize_attendance,list_late_employees,get_leave_balance,list_pending_leaves,search_company_policies,list_compliance_reminders,list_pending_approvals,list_applicants,analyze_resume,generate_document,save_document_content,generate_payroll_summary,export_payroll_xlsx,compute_final_pay,list_final_pay,create_compliance_reminder,create_leave_request,approve_leave_request,reject_leave_request,create_employee_draft,update_employee_draft

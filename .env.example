# Supabase project (https://supabase.com/dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI providers (at least one required; all three recommended) ---
# Groq: front desk — classification, Q&A, DB-query summaries, voice transcription (cheap + fast)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_CLASSIFIER_MODEL=llama-3.1-8b-instant

# OpenAI: premium task engine — document generation, structured tool execution, resume analysis
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude: premium long-form engine — disciplinary/legal-sensitive document drafting
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

APP_URL=http://localhost:3000
